{
    "name": "netzbewegung/nb-headless-content-blocks",
    "type": "typo3-cms-extension",
    "description": "Connects together EXT:headless and EXT:content_block",
    "keywords": [
        "TYPO3",
        "headless",
        "content_block",
        "json"
    ],
    "license": [
        "GPL-2.0-or-later"
    ],
    "authors": [
        {
            "name": "Uwe Raabe",
            "role": "Developer"
        },
        {
            "name": "Christoph Freund",
            "role": "Developer"
        },
        {
            "name": "Jana Deharde",
            "role": "Developer"
        },
        {
            "name": "Steffen Maechtel",
            "role": "Developer"
        },
        {
            "name": "Carsten Wilhelm",
            "role": "Developer"
        }
    ],
    "require": {
        "typo3/cms-core": "^13.4 || ^14.3",
        "friendsoftypo3/content-blocks": ">=1.2.3 || ^2.0",
        "friendsoftypo3/headless": "^4.5 || ^5.0"
    },
    "require-dev": {
        "typo3/testing-framework": "^9.5",
        "phpstan/phpstan": "^2.1",
        "phpstan/phpstan-phpunit": "^2.0",
        "bnf/phpstan-psr-container": "^1.1",
        "friendsofphp/php-cs-fixer": "^3.22",
        "typo3/coding-standards": "0.8.x-dev"
    },
    "autoload": {
        "psr-4": {
            "Netzbewegung\\NbHeadlessContentBlocks\\": "Classes"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Netzbewegung\\NbHeadlessContentBlocks\\Tests\\": "Tests"
        }
    },
    "extra": {
        "typo3/cms": {
            "extension-key": "nb_headless_content_blocks"
        }
    },
    "scripts": {
        "tests": [
            "Build/Scripts/runTests.sh -s cgl",
            "Build/Scripts/runTests.sh -s phpstan",
            "Build/Scripts/runTests.sh -s unit",
            "Build/Scripts/runTests.sh -s functional"
        ]
    }
}
